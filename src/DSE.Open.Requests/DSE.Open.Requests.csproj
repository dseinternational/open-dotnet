<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <!-- DSE.Open.Values.Generators emits public partial members (RequestId
         operators, Equals, Parse, etc.) into obj/ for which CS1591 fires
         despite the `<auto-generated/>` header; suppress for this project. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\gen\DSE.Open.Values.Generators\DSE.Open.Values.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\DSE.Open.Globalization\DSE.Open.Globalization.csproj" />
    <ProjectReference Include="..\DSE.Open.Serialization.DataTransfer\DSE.Open.Serialization.DataTransfer.csproj" />
    <ProjectReference Include="..\DSE.Open.Values.Abstractions\DSE.Open.Values.Abstractions.csproj" />
  </ItemGroup>

</Project>
